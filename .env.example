# Nombre visible de la aplicación en docs y responses.
APP_NAME=Despacho

# development | staging | production
APP_ENV=development

# Clave usada para cifrar config_json de canales.
# En producción usá una cadena larga, aleatoria y privada.
SECRET_KEY=cambiar-esto-por-una-clave-larga-y-segura

# SQLite local por defecto. Para producción conviene migrar a Postgres.
DATABASE_URL=sqlite:///./despacho.db

# Proveedor de IA principal: gemini o claude
AI_PROVIDER=gemini

# API key de Google AI Studio / Gemini
GEMINI_API_KEY=

# API key de Anthropic para fallback
CLAUDE_API_KEY=

# URL base de WordPress
WP_URL=https://debuenafedigital.com

# Usuario con permisos de publicación en WordPress
WP_USER=

# Application Password de WordPress, no la contraseña normal
WP_APP_PASSWORD=

# ID de la Facebook Page conectada al negocio
META_PAGE_ID=

# Access token de Meta con permisos sobre la página e Instagram Business
META_ACCESS_TOKEN=

# ID de la cuenta de Instagram Business o Creator habilitada para publishing
META_IG_ACCOUNT_ID=

# API key de X app
TWITTER_API_KEY=

# API secret de X app
TWITTER_API_SECRET=

# Access token del usuario que publicará
TWITTER_ACCESS_TOKEN=

# Access token secret del usuario que publicará
TWITTER_ACCESS_SECRET=

# Token del bot de Telegram
TELEGRAM_BOT_TOKEN=

# Chat ID o canal destino de Telegram
TELEGRAM_CHAT_ID=

# URL pública real desde donde Meta puede descargar imágenes.
# Ejemplo: https://despacho.midominio.com
# No sirve localhost para publicar en Instagram.
PUBLIC_BASE_URL=http://localhost:8000

# Versión de Graph API a usar en Meta
META_GRAPH_VERSION=v23.0

# Usuario del panel administrativo
PANEL_ADMIN_USERNAME=admin

# Contraseña del panel administrativo
PANEL_ADMIN_PASSWORD=admin

# Duración del token del panel en minutos
PANEL_TOKEN_TTL_MINUTES=720

# Frecuencia del scheduler en segundos
SCHEDULER_INTERVAL_SECONDS=30

# Switch maestro de auto publicación
AUTO_PUBLISH_GLOBAL=false

# Carpeta local de uploads originales y procesados
UPLOAD_DIR=./uploads

# Tamaño máximo permitido para imágenes subidas
MAX_IMAGE_SIZE_MB=10
